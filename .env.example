# Copiez ce fichier en .env et renseignez votre clé API Mistral.
# Obtenez une clé gratuite sur https://console.mistral.ai/
MISTRAL_API_KEY=__MISTRAL_API_KEY__

# Configuration de la base de données
# Remplacez les valeurs ci-dessous par les informations de connexion à votre base de données Aiven
DB_HOST=__DB_HOST__
DB_PORT=__DB_PORT__
DB_USER=__DB_USER__
DB_PASSWORD=__DB_PASSWORD__
DB_NAME=__DB_NAME__